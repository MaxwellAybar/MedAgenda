@model IEnumerable<MedAgenda.WebMVC.Models.SystemReportsDto>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">Listado de Reportes Generados</h3>
        </div>
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Título del Reporte</th>
                        <th>Descripción</th>
                        <th>Fecha de Creación</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td><strong>@item.Title</strong></td>
                                <td>@item.Description</td>
                                <td>@item.CreatedDate.ToShortDateString()</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center">No se han encontrado reportes en el sistema.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>>