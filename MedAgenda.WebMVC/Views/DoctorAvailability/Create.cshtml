@model MedAgenda.WebMVC.Models.DoctorAvailabilityDTO

@{
    ViewData["Title"] = "Nueva Disponibilidad";
}

<div class="container mt-4">
    <h2>Nueva Disponibilidad</h2>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label class="form-label">Doctor (ID)</label>
            <input asp-for="ProviderId" class="form-control" type="number" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Día</label>
            <select asp-for="Day" class="form-select" required>
                <option value="">Seleccione un día</option>
                <option value="1">Lunes</option>
                <option value="2">Martes</option>
                <option value="3">Miércoles</option>
                <option value="4">Jueves</option>
                <option value="5">Viernes</option>
                <option value="6">Sábado</option>
                <option value="7">Domingo</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Hora Inicio</label>
            <input asp-for="StartTime" class="form-control" type="time" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Hora Fin</label>
            <input asp-for="EndTime" class="form-control" type="time" required />
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-success">Guardar</button>
            <a asp-action="Index" class="btn btn-secondary">Volver</a>
        </div>
    </form>
</div>