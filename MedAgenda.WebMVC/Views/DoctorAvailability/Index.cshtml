@model List<MedAgenda.WebMVC.Models.DoctorAvailabilityDTO>

@{
    ViewData["Title"] = "Disponibilidad Médica";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Disponibilidad de Doctores</h2>
    <a asp-action="Create" class="btn btn-primary">
        + Nueva Disponibilidad
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Doctor (ProviderId)</th>
                <th>Día</th>
                <th>Horario</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.ProviderId</td>
                    <td>@item.Day</td>
                    <td>@item.StartTime - @item.EndTime</td>
                    <td>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('¿Seguro que desea eliminar esta disponibilidad?');">
                            <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center">No hay disponibilidades registradas.</td>
                </tr>
            }
        </tbody>
    </table>
</div>