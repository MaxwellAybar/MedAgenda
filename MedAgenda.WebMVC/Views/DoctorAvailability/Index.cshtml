@{
    ViewData["Title"] = "Doctor Availability";
}

<h2>Doctor Availability</h2>

<div>
    <label>Provider Id:</label>
    <input type="number" id="providerId" />
</div>

<div>
    <label>Day:</label>
    <input type="number" id="day" />
</div>

<div>
    <label>Start Time:</label>
    <input type="time" id="startTime" />
</div>

<div>
    <label>End Time:</label>
    <input type="time" id="endTime" />
</div>

<br />

<button onclick="addData()">Guardar</button>
<button onclick="loadData()">Cargar Datos</button>

<ul id="list"></ul>

<script>
    const API_URL = "https://localhost:7183/api/DoctorAvailability";

    async function loadData() {
        const response = await fetch(API_URL);
        const data = await response.json();

        const list = document.getElementById("list");
        list.innerHTML = "";

        data.forEach(item => {
            const li = document.createElement("li");
            li.innerText = `ID: ${item.id} - Day: ${item.day} (${item.startTime} - ${item.endTime})`;
            list.appendChild(li);
        });
    }

    async function addData() {
        const providerId = document.getElementById("providerId").value;
        const day = document.getElementById("day").value;
        const startTime = document.getElementById("startTime").value;
        const endTime = document.getElementById("endTime").value;

        await fetch(API_URL, {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                providerId: parseInt(providerId),
                day: parseInt(day),
                startTime: startTime,
                endTime: endTime
            })
        });

        alert("Guardado!");
    }
</script>