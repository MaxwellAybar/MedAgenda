@model MedAgenda.WebMVC.Models.PatientDto

@{
    ViewData["Title"] = "Registrar Paciente";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h2 class="mb-0">Registrar Nuevo Paciente</h2>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <input asp-for="FirstName" name="FirstName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Apellido</label>
                    <input asp-for="LastName" name="LastName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Correo Electrónico</label>
                    <input asp-for="Email" name="Email" type="email" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Teléfono</label>
                    <input asp-for="Phone" name="Phone" class="form-control" required placeholder="Ej: 809-000-0000" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Fecha de Nacimiento</label>
                    <input asp-for="DateOfBirth" name="DateOfBirth" type="date" class="form-control" required />
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success">Guardar Paciente</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Volver al Listado</a>
                </div>
            </form>
        </div>
    </div>
</div>