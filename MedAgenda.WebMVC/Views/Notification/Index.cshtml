@model IEnumerable<MedAgenda.WebMVC.Models.NotificationDto>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h3 class="mb-0">Panel de Notificaciones</h3>
        </div>
        <div class="card-body">
            <div class="list-group">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <div class="list-group-item list-group-item-action">
                            <div class="d-flex w-100 justify-content-between">
                                <h5 class="mb-1 text-primary">Aviso #@item.Id</h5>
                                <small class="text-muted">Recibido</small>
                            </div>
                            <p class="mb-1">@item.Message</p>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-light text-center">No hay notificaciones pendientes.</div>
                }
            </div>
        </div>
    </div>
</div>