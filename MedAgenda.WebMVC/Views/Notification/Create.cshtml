@model MedAgenda.WebMVC.Models.NotificationDto

<h2>Enviar Notificación</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">ID del Usuario</label>
        <input asp-for="UserId" class="form-control" type="number" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Mensaje</label>
        <textarea asp-for="Message" class="form-control" required></textarea>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsRead" class="form-check-input" type="checkbox" />
        <label class="form-check-label">Marcar como leída</label>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-warning">Enviar</button>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>
</form>