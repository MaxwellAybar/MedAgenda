@model IEnumerable<MedAgenda.WebMVC.Models.SystemHistoryDto>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white">
            <h3 class="mb-0">Historial de Actividades del Sistema</h3>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>ID Log</th>
                        <th>Usuario</th>
                        <th>Acción Realizada</th>
                        <th>Fecha y Hora</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.UserId</td>
                                <td>@item.Action</td>
                                <td>@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">No hay registros de historial.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>